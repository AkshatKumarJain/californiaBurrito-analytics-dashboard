PORT=4000
NODE_ENV=development

# Use DATABASE_URL in production if your MySQL provider gives one.
# DATABASE_URL=mysql://user:password@host:3306/california_burrito_analytics

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=california_burrito_analytics
DB_SSL=false

CORS_ORIGIN=http://localhost:5173
CACHE_TTL_SECONDS=60
CACHE_PROVIDER=auto
REDIS_URL=

AUTH_REQUIRED=false
AUTH_ALLOW_REGISTRATION=true
JWT_SECRET=replace-this-with-a-long-random-secret-before-deployment
JWT_EXPIRES_IN=1d

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Local ETL defaults. Override with --file when needed.
DATA_FILE=C:\Users\HP\Downloads\data.xlsx
IMPORT_BATCH_SIZE=1000
